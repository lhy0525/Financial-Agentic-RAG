# QA Test Credentials - Example
# Copy this file to config/test_credentials.yaml and fill in local credentials.
# Do not commit config/test_credentials.yaml.

deepseek:
  api_key: "<YOUR_DEEPSEEK_API_KEY>"
  model: "deepseek-chat"
  base_url: "https://api.deepseek.com"

